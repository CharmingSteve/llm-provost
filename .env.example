# === LLM API ===
LLM_API_URL=https://api.openai.com
LLM_API_KEY=your-llm-api-key

# === AWS / Fluent Bit ===
S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# === Cognito OIDC (Production) ===
OPENID_CLIENT_ID=your-cognito-client-id
OPENID_CLIENT_SECRET=your-cognito-client-secret
OPENID_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_SESSION_SECRET=change-this-to-a-random-string

# === LibreChat / OpenAI ===
OPENAI_API_KEY=your-openai-api-key
OPENAI_REVERSE_PROXY=https://your-openwire-endpoint/v1/chat/completions

# === Meilisearch ===
MEILI_MASTER_KEY=provost-dev-meili-key